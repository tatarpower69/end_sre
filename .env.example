# Database Secrets
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=microservices_db
GRAFANA_PASSWORD=admin

# Service Ports
AUTH_PORT=8001
USER_PORT=8002
PRODUCT_PORT=8003
ORDER_PORT=8004
CHAT_PORT=8005
PAYMENT_PORT=8006
NOTIFICATION_PORT=8007
NGINX_PORT=80

# Monitoring Ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# API Configuration
ALLOWED_ORIGINS=*
DATABASE_URL=postgresql://your_db_user:your_db_password@db:5432/microservices_db
